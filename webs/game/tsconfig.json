{
  "extends": "@tera/typescript-config/react-library.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@tera/game/pages/*": ["src/pages/*"],
      "@tera/game/routers/*": ["src/routers/*"],
      "@tera/game/states/*": ["src/states/*"],
      "@tera/game/assets/*": ["src/assets/*"],
      "@tera/game/engine/*": ["src/engine/*"],
      "@tera/game/screen/*": ["src/screen/*"],
      "@tera/game/ui/*": ["src/ui/*"],
      "@tera/game/_common/*": ["src/_common/*"],
      "@tera/commons/*": ["../../packages/commons/src/*"],
      "@tera/components/*": ["../../packages/components/src/*"],
      "@tera/assets/*": ["../../packages/assets/src/*"],
      "@tera/themes/*": ["../../packages/themes/src/*"],
      "@tera/stores/*": ["../../services/stores/src/*"],
      "@tera/api/*": ["../../services/api/src/*"],
      "@tera/modules/*": ["../../services/modules/src/*"],
      "tailwind-merge.config": ["src/tailwind-merge.config.ts"],
      "~/*": ["./*"],
      "@/*": ["src/*"],
      "src/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
