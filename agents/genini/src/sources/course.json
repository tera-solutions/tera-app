{
  "module": "education",
  "prefix": "edu",
  "entity": "course",
  "block": "course",
  "title": "khóa học",
  "mode": "modal",
  "router": {
    "list": "/course/list",
    "create": "/course/create",
    "update": "/course/update/:id",
    "detail": "/course/detail/:id"
  },
  "buttons": ["create", "detail", "update", "delete", "export", "filter"],
  "fields": [
    {
      "key": "code",
      "title": "Mã khóa học",
      "required": true,
      "type": "string",
      "width": 200
    },
    {
      "key": "name",
      "title": "Tên khóa học",
      "required": true,
      "type": "string",
      "width": 200
    },
    {
      "key": "level_id",
      "title": "Cấp độ",
      "required": true,
      "type": "number",
      "width": 200
    },
    {
      "key": "program_id",
      "title": "Chương trình",
      "required": true,
      "type": "number",
      "width": 200
    },
    {
      "key": "duration",
      "title": "Thời gian",
      "required": true,
      "type": "number",
      "width": 100
    },
    {
      "key": "price",
      "title": "Học phí",
      "required": true,
      "type": "number",
      "width": 200
    }
  ]
}
