{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "VITE_TERA_API",
    "VITE_TERA_SOCKET",
    "VITE_GOOGLE_OAUTH_CLIENT_ID",
    "VITE_MICROSOFT_OAUTH_CLIENT_ID",
    "VITE_MICROSOFT_OAUTH_TENANT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$VITE_TERA_API",
        "$VITE_TERA_SOCKET",
        ".env*"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
