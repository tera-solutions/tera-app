{
  "expo": {
    "name": "Hana Student",
    "displayName": "Hana Student",
    "slug": "hana-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/ic_launcher.png",
    "scheme": "hana-student",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "./src/assets/fonts/*",
      "./src/assets/images/*",
      "./src/assets/icons/*"
    ],
    "splash": {
      "image": "./src/assets/images/logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f9bdb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tera.app.hana.student",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Hana Student"
      }
    },
    "android": {
      "name": "Hana Student",
      "adaptiveIcon": {
        "backgroundColor": "#0095d9",
        "foregroundImage": "./src/assets/images/android_launcher.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "tera.app.hana.student"
    },
    "web": {
      "output": "web",
      "favicon": "./src/assets/images/favicon.png",
      "build": {
        "babel": {
          "allowRelativeFirstImports": true
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logo-white.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f9bdb"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08c3657a-2b9d-4398-b5aa-403ea188f79d"
      }
    }
  }
}
