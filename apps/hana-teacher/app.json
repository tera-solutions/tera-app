{
  "expo": {
    "name": "Hana Teacher",
    "displayName": "Hana Teacher",
    "slug": "hana-teacher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/ic_launcher.png",
    "scheme": "hana-teacher",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "./src/assets/fonts/*",
      "./src/assets/images/*",
      "./src/assets/icons/*"
    ],
    "splash": {
      "image": "./src/assets/images/logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f9bdb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "terasolutions.hana.teacher",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Hana Teacher",
        "UIBackgroundModes": ["fetch", "processing", "location"],
        "NSBluetoothAlwaysUsageDescription": "Ứng dụng cần truy cập Bluetooth để tìm kiếm và kết nối máy in hóa đơn.",
        "NSBluetoothPeripheralUsageDescription": "Ứng dụng cần Bluetooth để giao tiếp với máy in nhiệt.",
        "NSLocalNetworkUsageDescription": "Ứng dụng cần truy cập mạng nội bộ để kết nối với máy in IP/LAN.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Ứng dụng cần vị trí để shipper cập nhật lộ trình giao hàng.",
        "NSLocationAlwaysUsageDescription": "Ứng dụng cần vị trí chạy ngầm để tối ưu đơn hàng gần bạn.",
        "NSLocationWhenInUseUsageDescription": "Ứng dụng cần vị trí để xác định kho hàng gần nhất.",
        "UISupportedExternalAccessoryProtocols": [
          "com.epson.escpos",
          "com.btprinter.protocol"
        ],
        "NSBonjourServices": ["_printer._tcp.", "_http._tcp."]
      }
    },
    "android": {
      "name": "Hana Teacher",
      "adaptiveIcon": {
        "backgroundColor": "#0095d9",
        "foregroundImage": "./src/assets/images/android_launcher.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "terasolutions.hana.teacher",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "ACCESS_FINE_LOCATION",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "output": "web",
      "favicon": "./src/assets/images/favicon.png",
      "build": {
        "babel": {
          "allowRelativeFirstImports": true
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logo-white.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f9bdb"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/MaterialCommunityIcons.ttf",
            "./src/assets/fonts/Roboto-Regular.ttf",
            "./src/assets/fonts/Roboto-Bold.ttf",
            "./src/assets/fonts/Roboto-Medium.ttf",
            "./src/assets/fonts/Roboto-Italic.ttf",
            "./src/assets/fonts/Roboto-Light.ttf",
            "./src/assets/fonts/Roboto-Thin.ttf",
            "./src/assets/fonts/Roboto-ExtraBold.ttf"
          ]
        }
      ],
      "expo-web-browser",
      "expo-task-manager",
      "expo-background-fetch",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Cho phép truy cập vị trí ngay cả khi đóng ứng dụng."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "08c3657a-2b9d-4398-b5aa-403ea188f79d"
      }
    }
  }
}
