{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app"],
      "@tera/commons/*": ["../../packages/commons/src/*"],
      "@tera/components/*": ["../../packages/components/src/*"],
      "@tera/assets/*": ["../../packages/assets/src/*"],
      "@tera/databases/*": ["../../services/databases/src/*"],
      "@tera/modules/*": ["../../services/modules/src/*"],
      "@tera/stores/*": ["../../services/store/src/*"],
      "@tera/api/*": ["../../services/api/src/*"],
      "@provider/*": ["src/provider/*"],
      "@hooks/*": ["src/hooks/*"],
      "@components/*": ["src/components/*"],
      "@types/*": ["src/types/*"],
      "@assets/*": ["src/assets/*"],
      "@navigation/*": ["src/navigation/*"],
      "@screens/*": ["src/screens/*"],
      "@states/*": ["src/states/*"],
      "@services/*": ["src/services/*"],
      "@databases/*": ["src/databases/*"],
      "@styles/*": ["src/styles/*"],
      "@modules/*": ["src/modules/*"],
      "@ecommerce/*": ["src/modules/ecommerce/*"],
      "@finance/*": ["src/modules/finance/*"],
      "@setting/*": ["src/modules/setting/*"],
      "@logistic/*": ["src/modules/logistic/*"],
      "@marketing/*": ["src/modules/marketing/*"],
      "@operation/*": ["src/modules/operation/*"],
      "@purchase/*": ["src/modules/purchase/*"],
      "@sale/*": ["src/modules/sale/*"],
      "@warehouse/*": ["src/modules/warehouse/*"]
    },
    "jsx": "react-native",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "modules/**/*.ts",
    "modules/**/*.tsx"
  ]
}
